generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum UserRole {
  USER
  OPERATOR
  ADMIN
}

enum DifficultyLevel {
  EASY
  MODERATE
  HARD
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
  REFUNDED
}

enum ChatRole {
  USER
  ASSISTANT
}

model User {
  id              String            @id @default(cuid())
  name            String?
  email           String            @unique
  emailVerified   DateTime?
  image           String?
  passwordHash    String?
  role            UserRole          @default(USER)
  isSuspended     Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  accounts        Account[]
  sessions        Session[]
  bookings        Booking[]
  reviews         Review[]
  favorites       Favorite[]
  operatorProfile OperatorProfile?
  chatMessages    ChatMessage[]
  notifications   Notification[]

  @@index([role])
}

model OperatorProfile {
  id               String    @id @default(cuid())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String    @unique
  businessName     String
  description      String
  logoUrl          String?
  phone            String
  isVerified       Boolean   @default(false)
  verificationDocs String[]
  rating           Float     @default(0)
  totalBookings    Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  listings         Listing[]

  @@index([isVerified])
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  icon        String?
  description String?
  listings    Listing[]
}

model Destination {
  id             String    @id @default(cuid())
  name           String
  slug           String    @unique
  district       String
  region         String
  description    String
  heroImageUrl   String?
  latitude       Float
  longitude      Float
  bestSeason     String
  difficultyTags String[]
  listings       Listing[]

  @@index([region])
}

model Listing {
  id               String             @id @default(cuid())
  title            String
  slug             String             @unique
  operator         OperatorProfile    @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  operatorId       String
  category         Category           @relation(fields: [categoryId], references: [id])
  categoryId       String
  destination      Destination        @relation(fields: [destinationId], references: [id])
  destinationId    String
  shortDescription String
  fullDescription  String
  pricePerPerson   Int
  discountPrice    Int?
  durationHours    Int?
  durationDays     Int?
  groupSizeMin     Int
  groupSizeMax     Int
  difficultyLevel  DifficultyLevel
  inclusions       String[]
  exclusions       String[]
  thingsToCarry    String[]
  images           String[]
  status           ListingStatus      @default(DRAFT)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  avgRating        Float              @default(0)
  itineraryDays    ItineraryDay[]
  availabilitySlots AvailabilitySlot[]
  bookings         Booking[]
  reviews          Review[]
  favorites        Favorite[]

  @@index([operatorId])
  @@index([categoryId])
  @@index([destinationId])
  @@index([status])
  @@index([avgRating])
}

model ItineraryDay {
  id          String   @id @default(cuid())
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId   String
  dayNumber   Int
  title       String
  description String
  activities  String[]

  @@unique([listingId, dayNumber])
  @@index([listingId])
}

model AvailabilitySlot {
  id          String   @id @default(cuid())
  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId   String
  date        DateTime
  startTime   String
  capacity    Int
  bookedCount Int      @default(0)
  isActive    Boolean  @default(true)
  bookings    Booking[]

  @@index([listingId])
  @@index([date])
  @@index([isActive])
}

model Booking {
  id               String          @id @default(cuid())
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  listing          Listing         @relation(fields: [listingId], references: [id])
  listingId        String
  slot             AvailabilitySlot @relation(fields: [slotId], references: [id])
  slotId           String
  coupon           Coupon?         @relation(fields: [couponId], references: [id])
  couponId         String?
  numberOfPeople   Int
  totalAmount      Int
  discountAmount   Int             @default(0)
  status           BookingStatus   @default(PENDING)
  bookingReference String          @unique
  specialRequests  String?
  tripDate         DateTime
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  payment          Payment?
  review           Review?

  @@index([userId])
  @@index([listingId])
  @@index([slotId])
  @@index([status])
  @@index([tripDate])
}

model Payment {
  id                String        @id @default(cuid())
  booking           Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId         String        @unique
  razorpayOrderId   String
  razorpayPaymentId String?
  amount            Int
  currency          String        @default("INR")
  status            PaymentStatus @default(CREATED)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([razorpayOrderId])
  @@index([razorpayPaymentId])
  @@index([status])
}

model Review {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId  String
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId  String   @unique
  rating     Int
  comment    String
  images     String[]
  reply      String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([listingId])
}

model Favorite {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}

model ChatMessage {
  id        String    @id @default(cuid())
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  sessionId String
  role      ChatRole
  content   String
  createdAt DateTime  @default(now())

  @@index([sessionId])
  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([isRead])
}

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  discountPercent Int
  validFrom       DateTime
  validTo         DateTime
  maxUses         Int
  usedCount       Int       @default(0)
  bookings        Booking[]

  @@index([validFrom, validTo])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
